# === DeepSeek LLM ===
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === CORS ===
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# === MeiliSearch ===
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=yujing-master-secret-key-123456
DATABASE_PATH=runtime/db/yujing.db
MEILI_BINARY_PATH=runtime/meili/meilisearch-windows-amd64.exe
MEILI_DB_PATH=runtime/meili/data.ms

# === 早报定时生成 ===
BRIEF_HOUR=8
BRIEF_MINUTE=0
# 调试用：设为正整数则按间隔触发（如 1 = 每1分钟），留空则用 BRIEF_HOUR/MINUTE
# BRIEF_INTERVAL_MINUTES=1

# === 舆情异动告警 ===
# ALERT_THRESHOLD=3
# ALERT_WINDOW_HOURS=2
# 调试用：设为 1 则阈值降为1，不限时间窗口
# ALERT_DEBUG=1

# === v0.10 · 语义聚类升级（Sentence-BERT，默认关闭）===
# 设为 1 后，rebuild_events 默认走 Sentence-BERT 语义聚类路径（失败自动回退 Jaccard）。
# 不设或设为 0 时行为完全与旧版一致，零侵入。
# SEMANTIC_CLUSTER=1

# 向量模型（可换为 BAAI/bge-base-zh-v1.5 提升效果但推理变慢 ~3x）
# EMBED_MODEL=BAAI/bge-small-zh-v1.5
# EMBED_DIM=512
# EMBED_BATCH=16
# EMBED_MAX_LENGTH=128

# 国内推荐：设为 1 后 embedding.py 启动时自动把 HF_ENDPOINT 指到 hf-mirror.com，
# 并解除 HF_HUB_OFFLINE / TRANSFORMERS_OFFLINE，首次下载约 30 秒拿下 100 MB 权重。
# EMBED_USE_MIRROR=1

# 聚类阈值（W3 评测后会给出推荐值）
# SEMANTIC_CLUSTER_THRESHOLD=0.62
# SEMANTIC_TOPK=20
# SEMANTIC_W_COS=0.60
# SEMANTIC_W_TIME=0.25
# SEMANTIC_W_PLATFORM=0.15
# SEMANTIC_TIME_HALF_LIFE_HOURS=12
