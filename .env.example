# === DeepSeek LLM ===
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === CORS ===
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# === MeiliSearch ===
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=yujing-master-secret-key-123456
DATABASE_PATH=runtime/db/yujing.db
MEILI_BINARY_PATH=runtime/meili/meilisearch-windows-amd64.exe
MEILI_DB_PATH=runtime/meili/data.ms

# === 早报定时生成 ===
BRIEF_HOUR=8
BRIEF_MINUTE=0
# 调试用：设为正整数则按间隔触发（如 1 = 每1分钟），留空则用 BRIEF_HOUR/MINUTE
# BRIEF_INTERVAL_MINUTES=1

# === 舆情异动告警 ===
# ALERT_THRESHOLD=3
# ALERT_WINDOW_HOURS=2
# 调试用：设为 1 则阈值降为1，不限时间窗口
# ALERT_DEBUG=1
